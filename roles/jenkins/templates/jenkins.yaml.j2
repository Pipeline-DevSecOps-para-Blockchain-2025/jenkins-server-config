jenkins:
  authorizationStrategy:
    globalMatrix:
      entries:
        - user:
            name: anonymous
            permissions:
              - Job/Read
              - Metrics/View
              - Overall/Read
              - View/Read
        - group:
            name: authenticated
            permissions:
              - Overall/Administer
  markupFormatter:
    rawHtml:
      disableSyntaxHighlighting: false
  numExecutors: 0
  clouds:
    - docker:
        name: local-docker
        dockerApi:
          dockerHost:
            uri: tcp://dockerd:2375
        exposeDockerHost: true
        templates:
          - labelString: docker-agent
            pullStrategy: PULL_ALWAYS
            dockerTemplateBase:
              image: docker.io/jenkins/inbound-agent:alpine
            remoteFs: /home/jenkins/agent
            connector:
              jnlp:
                jenkinsUrl: http://jenkins:8080
            instanceCapStr: '{{ jenkins_dind_agents }}'
            retentionStrategy:
                idleMinutes: 1
            stopTimeout: 10
  securityRealm:
    local:
      allowsSignup: false
      users:
        {%- for id, user in users.items() +%}
        - id: '{{ id }}'
          name: '{{ user.name }}'
          password: '#jbcrypt:{{ user.jenkins_password }}'
          properties:
            - mailer:
                emailAddress: '{{ user.email }}'
            - timezone:
                timeZoneName: '{{ user.timezone }}'
        {%- endfor +%}
  slaveAgentPort: 50000

appearance:
  pipelineGraphView:
    showGraphOnBuildPage: true
    showGraphOnJobPage: true
    showStageDurations: true
    showStageNames: true
  themeManager:
    disableUserThemes: true
    theme: dark

security:
  contentSecurityPolicy:
    enforce: true
  gitHostKeyVerificationConfiguration:
    sshHostKeyVerificationStrategy: knownHostsFileVerificationStrategy

credentials:
  system:
    domainCredentials:
      - credentials:
          - gitHubApp:
              id: Pipeline-DevSecOps-Jenkins
              appID: '{{ github_app_id }}'
              privateKey: '${readFile:/secrets/jenkins/GITHUB_APP_PRIVATE_KEY}'
              repositoryAccessStrategy: inferOwner
          - string:
              id: GitHub Shared Secret
              scope: SYSTEM
              secret: '${GITHUB_SHARED_SECRET}'
          - string:
              id: GitHub Client Secret
              scope: SYSTEM
              secret: '${GITHUB_CLIENT_SECRET}'
          - string:
              id: GitHub Personal Access Token
              scope: SYSTEM
              secret: '${GITHUB_PAT}'

tool:
  dockerTool:
    installations:
      - name: docker
        properties:
          - installSource:
              installers:
                - fromDocker:
                    version: '29.3.0'

unclassified:
  audit-trail:
    logBuildCause: true
    logCredentialsUsage: true
    pattern: '.*/(?:configSubmit|doDelete|postBuildResult|enable|disable|cancelQueue|stop|toggleLogKeep|doWipeOutWorkspace|createItem|createView|toggleOffline|cancelQuietDown|quietDown|restart|exit|safeExit)/?.*'
  defaultFolderConfiguration:
    healthMetrics:
      - primaryBranchHealthMetric
  gitHubConfiguration:
    apiRateLimitChecker: ThrottleForNormalize
  gitHubPluginConfig:
    configs:
      - credentialsId: GitHub Personal Access Token
        name: Pipeline-DevSecOps-para-Blockchain-2025
    hookSecretConfigs:
      - credentialsId: GitHub Shared Secret
        signatureAlgorithm: SHA256
    hookUrl: '{{ 'https' if configure_tls else 'http' }}://{{ server_domain }}/github-webhook/'
  location:
    adminAddress: '{{ admin_email }}'
    url: '{{ 'https' if configure_tls else 'http' }}://{{ server_domain }}/'
