jenkins:
  authorizationStrategy:
    globalMatrix:
      entries:
        - user:
            name: anonymous
            permissions:
              - Job/Read
              - Metrics/View
              - Overall/Read
              - View/Read
        - group:
            name: authenticated
            permissions:
              - Overall/Administer
  markupFormatter:
    rawHtml:
      disableSyntaxHighlighting: false
  numExecutors: 0
  clouds:
    - docker:
        name: local-docker
        dockerApi:
          dockerHost:
            uri: tcp://dockerd:2375
        exposeDockerHost: true
        templates:
          - labelString: docker-agent
            pullStrategy: PULL_ALWAYS
            dockerTemplateBase:
              image: docker.io/jenkins/inbound-agent:alpine
              mountsString: type=bind,source=/usr/local/bin/docker,destination=/usr/local/bin/docker,readonly=true
            remoteFs: /home/jenkins/agent
            connector:
              jnlp:
                jenkinsUrl: http://jenkins:8080
            instanceCapStr: '{{ jenkins_dind_agents }}'
            retentionStrategy:
                idleMinutes: 1
            stopTimeout: 10
  securityRealm:
    local:
      allowsSignup: false
      users:
        {%- for id, user in users.items() +%}
        - id: '{{ id }}'
          name: '{{ user.name }}'
          password: '#jbcrypt:{{ user.jenkins_password }}'
          properties:
            - mailer:
                emailAddress: '{{ user.email }}'
            - timezone:
                timeZoneName: '{{ user.timezone }}'
        {%- endfor +%}
  slaveAgentPort: 50000

appearance:
  pipelineGraphView:
    showGraphOnBuildPage: true
    showGraphOnJobPage: true
    showStageDurations: true
    showStageNames: true
  themeManager:
    disableUserThemes: true
    theme: dark

security:
  contentSecurityPolicy:
    enforce: true
  gitHostKeyVerificationConfiguration:
    sshHostKeyVerificationStrategy: knownHostsFileVerificationStrategy
  scriptApproval:
    approvedSignatures:
      - method java.net.http.HttpClient send java.net.http.HttpRequest java.net.http.HttpResponse$BodyHandler
      - method java.net.http.HttpRequest$Builder POST java.net.http.HttpRequest$BodyPublisher
      - method java.net.http.HttpRequest$Builder build
      - method java.net.http.HttpRequest$Builder header java.lang.String java.lang.String
      - method java.net.http.HttpRequest$Builder uri java.net.URI
      - method java.net.http.HttpResponse body
      - method java.net.http.HttpResponse statusCode
      - staticMethod java.net.URI create java.lang.String
      - staticMethod java.net.http.HttpClient newHttpClient
      - staticMethod java.net.http.HttpRequest newBuilder
      - staticMethod java.net.http.HttpRequest$BodyPublishers ofString java.lang.String
      - staticMethod java.net.http.HttpResponse$BodyHandlers ofString
      - staticMethod org.codehaus.groovy.runtime.DefaultGroovyMethods min java.util.Collection

credentials:
  system:
    domainCredentials:
      - credentials:
          - gitHubApp:
              id: Pipeline-DevSecOps-Jenkins
              appID: '{{ github_app_id }}'
              privateKey: '${readFile:/secrets/jenkins/GITHUB_APP_PRIVATE_KEY}'
              repositoryAccessStrategy: inferOwner
          - string:
              id: GitHub Shared Secret
              scope: SYSTEM
              secret: '${GITHUB_SHARED_SECRET}'
          - string:
              id: GitHub Client Secret
              scope: SYSTEM
              secret: '${GITHUB_CLIENT_SECRET}'
          - string:
              id: GitHub Personal Access Token
              scope: SYSTEM
              secret: '${GITHUB_PAT}'

jobs:
  {%- for job in jobs +%}
  - script: |
{{ lookup('file', 'jobs/' ~ job) | indent(6, true) }}
  {%- endfor +%}

unclassified:
  audit-trail:
    logBuildCause: true
    logCredentialsUsage: true
    pattern: '.*/(?:configSubmit|doDelete|postBuildResult|enable|disable|cancelQueue|stop|toggleLogKeep|doWipeOutWorkspace|createItem|createView|toggleOffline|cancelQuietDown|quietDown|restart|exit|safeExit)/?.*'
  defaultFolderConfiguration:
    healthMetrics:
      - primaryBranchHealthMetric
  scmGit:
    hideCredentials: true
  gitHubConfiguration:
    apiRateLimitChecker: ThrottleForNormalize
  gitHubPluginConfig:
    configs:
      - credentialsId: GitHub Personal Access Token
        name: Pipeline-DevSecOps-para-Blockchain-2025
    hookSecretConfigs:
      - credentialsId: GitHub Shared Secret
        signatureAlgorithm: SHA256
    hookUrl: '{{ 'https' if configure_tls else 'http' }}://{{ server_domain }}/github-webhook/'
  location:
    adminAddress: '{{ admin_email }}'
    url: '{{ 'https' if configure_tls else 'http' }}://{{ server_domain }}/'
