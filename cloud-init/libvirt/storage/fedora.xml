<?xml-model href="/usr/share/libvirt/schemas/storagevol.rng"?>
<!--
Ephemeral overlay on top of fedora-base.qcow2:
```sh
virsh vol-delete testing fedora.qcow2
virsh vol-create testing local/libvirt/storage/fedora.xml
```
-->
<volume type='file'>
  <name>fedora.qcow2</name>
  <capacity unit='GiB'>20</capacity>
  <backingStore>
    <path>/var/lib/libvirt/testing/fedora-base.qcow2</path>
    <format type='qcow2' />
  </backingStore>
  <target>
    <format type='qcow2' />
    <compat>1.1</compat>
  </target>
</volume>
